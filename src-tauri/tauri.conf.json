{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Size Intelligence Studio",
  "version": "0.1.0",
  "identifier": "studio.size-intelligence.local",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Size Intelligence Studio",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "Productivity",
    "shortDescription": "Local-first clothing size recommendation studio",
    "longDescription": "A local-first desktop expert tool for body profiles, clothing size guides, and deterministic recommendation sessions."
  }
}
